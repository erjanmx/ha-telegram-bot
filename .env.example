# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow ALL users (not recommended for a personal HA bot).
# Get your ID by messaging @userinfobot on Telegram.
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321

# ── Home Assistant ─────────────────────────────────────────────────────────────
# Base URL of your HA instance (no trailing slash).
# If using a reverse proxy: https://ha.yourdomain.com
HA_URL=https://ha.yourdomain.com

# Long-Lived Access Token from HA:
#   Profile → Security → Long-Lived Access Tokens → Create Token
HA_TOKEN=your_ha_long_lived_access_token_here

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. Recommended: claude-sonnet-4-6 (fast + capable)
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ── Tuning ────────────────────────────────────────────────────────────────────
# Number of conversation turns to keep per user (controls context / cost).
MAX_HISTORY_MESSAGES=20
